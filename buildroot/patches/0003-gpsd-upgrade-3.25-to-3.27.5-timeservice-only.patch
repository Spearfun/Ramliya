From: Spearfun
Subject: [PATCH 0003] gpsd: upgrade 3.25 -> 3.27.5, timeservice-only build

Strip gpsd to a dedicated timeservice appliance profile:
- No client applications (gpsdclients=no)
- No network feed or NTRIP (netfeed=false, ntrip=false)
- No control socket (control_socket=false)
- Fixed port speed 9600 baud, max_devices=1, max_clients=0
- Explicit timeservice=yes

---
 package/gpsd/gpsd.hash |  2 +-
 package/gpsd/gpsd.mk   | 16 +++++++++++++---
 2 files changed, 14 insertions(+), 4 deletions(-)

diff --git a/package/gpsd/gpsd.mk b/package/gpsd/gpsd.mk
index 1111111..2222222 100644
--- a/package/gpsd/gpsd.mk
+++ b/package/gpsd/gpsd.mk
@@ -4,7 +4,7 @@
 #
 ################################################################################
 
-GPSD_VERSION = 3.25
+GPSD_VERSION = 3.27.5
 GPSD_SITE = http://download-mirror.savannah.gnu.org/releases/gpsd
 GPSD_LICENSE = BSD-2-Clause
 GPSD_LICENSE_FILES = COPYING
@@ -28,11 +28,19 @@
 
 GPSD_SCONS_OPTS = \
 	arch=$(ARCH) \
-	manbuild=no \
 	prefix=/usr \
 	sysroot=$(STAGING_DIR) \
-	strip=no \
-	qt=no
+	manbuild=false \
+	strip=true \
+	qt=false \
+	netfeed=false \
+	ntrip=false \
+	control_socket=false \
+	timeservice=yes \
+	gpsdclients=no \
+	max_clients=0 \
+	max_devices=1 \
+	fixed_port_speed=9600
 
 ifeq ($(BR2_PACKAGE_NCURSES),y)
 GPSD_DEPENDENCIES += ncurses
diff --git a/package/gpsd/gpsd.hash b/package/gpsd/gpsd.hash
index 1111111..2222222 100644
--- a/package/gpsd/gpsd.hash
+++ b/package/gpsd/gpsd.hash
@@ -1,3 +1,3 @@
 # Locally calculated
-sha256  b368b6a305e3f7a6382d23a0cbfc1d78923060b6b7f54cf7987a73c7b4a9afc2  gpsd-3.25.tar.gz
+sha256  409873f5048462ef1ac413a51ab35caa8b50b31be62b3347bee1cc2994e7c649  gpsd-3.27.5.tar.gz
 sha256  fdf339997bbca9eaf507476b82fbcac608fc39a3d89b86b51e16db4c9f933716  COPYING
