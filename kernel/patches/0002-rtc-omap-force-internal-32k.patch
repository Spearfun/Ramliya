diff --git a/drivers/rtc/rtc-omap.c b/drivers/rtc/rtc-omap.c
index c20fc7937..91dbce2b7 100644
--- a/drivers/rtc/rtc-omap.c
+++ b/drivers/rtc/rtc-omap.c
@@ -846,6 +846,17 @@ static int omap_rtc_probe(struct platform_device *pdev)
 		reg &= ~OMAP_RTC_OSC_OSC32K_GZ_DISABLE;
 		reg |= OMAP_RTC_OSC_32KCLK_EN | OMAP_RTC_OSC_SEL_32KCLK_SRC;
 		rtc_writel(rtc, OMAP_RTC_OSC_REG, reg);
+	} else {
+		/*
+		 * L3+ board has no external 32k crystal. The OSC source
+		 * select bit persists in the always-on RTC domain, so a
+		 * stale SEL_32KCLK_SRC=external left by a previous boot
+		 * freezes the counter. Force the internal 32k source.
+		 */
+		reg = rtc_read(rtc, OMAP_RTC_OSC_REG);
+		reg &= ~OMAP_RTC_OSC_SEL_32KCLK_SRC;
+		reg |= OMAP_RTC_OSC_32KCLK_EN;
+		rtc_writel(rtc, OMAP_RTC_OSC_REG, reg);
 	}
 
 	rtc->type->lock(rtc);
